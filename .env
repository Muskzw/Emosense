# EmoSense Backend Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# CORS — comma-separated list of allowed origins
# Example: https://emosense.app,https://www.emosense.app
ALLOWED_ORIGINS=*

# TURN Server credentials (get free from https://dashboard.metered.ca/)
# Without this, cross-network calls (ZW ↔ CN) may fail
TURN_URL=turn:your-turn-server.metered.ca:80
TURN_USERNAME=your_username
TURN_PASSWORD=your_password

# Admin key for /api/sessions endpoint
ADMIN_KEY=change-this-to-a-random-secret