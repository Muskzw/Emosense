# EmoSense Backend Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# CORS — comma-separated list of allowed origins
# Example: https://emosense.app,https://www.emosense.app
ALLOWED_ORIGINS=*

# TURN Server credentials (get free from https://dashboard.metered.ca/)
